# Auto normalize line endings for all text files
* text=auto

# Shell scripts must use Unix line endings
*.sh text eol=lf
*.bash text eol=lf
kafka-stream-job/scripts/ensure text eol=lf

# Batch files must use Windows line endings
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Docker files
Dockerfile* text eol=lf
*.docker text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JSON and XML
*.json text eol=lf
*.xml text eol=lf

# Source code
*.java text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
